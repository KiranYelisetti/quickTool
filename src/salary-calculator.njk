                <div class="space-y-4">
                    <details class="group bg-gray-50 dark:bg-gray-700 rounded-lg p-4 cursor-pointer">
                        <summary class="font-semibold text-gray-800 dark:text-white flex justify-between items-center">Why is my in-hand salary so much less than CTC?<i class="fas fa-chevron-down text-gray-500 transition-transform group-open:rotate-180"></i></summary>
                        <p class="mt-3 text-gray-600 dark:text-gray-300 text-sm">CTC includes employer contributions to PF (12% of Basic), Gratuity (4.81% of Basic), and sometimes insurance premiums and ESIC. These never reach your bank account directly. On top of that, employee PF (12%), Professional Tax, and Income Tax (TDS) are deducted from your gross salary.</p>
                    </details>
                    <details class="group bg-gray-50 dark:bg-gray-700 rounded-lg p-4 cursor-pointer">
                        <summary class="font-semibold text-gray-800 dark:text-white flex justify-between items-center">Should I opt for higher Basic pay or lower?<i class="fas fa-chevron-down text-gray-500 transition-transform group-open:rotate-180"></i></summary>
                        <p class="mt-3 text-gray-600 dark:text-gray-300 text-sm">Higher Basic = Higher PF contribution (good for retirement savings) but lower in-hand pay. Lower Basic = Higher Special Allowance = Higher in-hand but lower PF. If you're in the Old Tax Regime with HRA benefits, a balanced 40% Basic is usually optimal.</p>
                    </details>
                    <details class="group bg-gray-50 dark:bg-gray-700 rounded-lg p-4 cursor-pointer">
                        <summary class="font-semibold text-gray-800 dark:text-white flex justify-between items-center">What is the PF contribution ceiling?<i class="fas fa-chevron-down text-gray-500 transition-transform group-open:rotate-180"></i></summary>
                        <p class="mt-3 text-gray-600 dark:text-gray-300 text-sm">The statutory PF contribution is calculated on Basic pay up to ₹15,000/month. However, many companies voluntarily compute PF on the full Basic salary. This calculator uses 12% of full Basic for both employee and employer contributions.</p>
                    </details>
                </div>
            </div>
        </div>
    </div>

    <!-- Financial Disclaimer -->
    <div class="mt-12 bg-yellow-50 dark:bg-yellow-900 dark:bg-opacity-20 border-l-4 border-yellow-500 p-6 max-w-5xl mx-auto mb-8 rounded-r-lg">
        <div class="flex items-start">
            <i class="fas fa-exclamation-triangle text-yellow-600 text-2xl mr-4 flex-shrink-0 mt-1"></i>
            <div>
                <h3 class="font-bold text-gray-800 dark:text-white mb-2">Important Disclaimer</h3>
                <div class="text-sm text-gray-700 dark:text-gray-300 space-y-2">
                    <p><strong>For Informational Purposes Only:</strong> This calculator provides salary estimates based on a standard CTC structure. Actual salary components vary by company.</p>
                    <p><strong>TDS is Estimated:</strong> Income tax (TDS) shown is a rough estimate using the New Tax Regime. Your actual TDS may differ based on declarations submitted to your employer.</p>
                    <p><strong>No Liability:</strong> QuickTools India assumes no responsibility for any decisions or actions taken based on the salary calculations provided on this tool.</p>
                </div>
            </div>
        </div>
    </div>
</main>

{% block scripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        initAutoSave('salary_calc');
        calculateSalary();
    });

    function fmt(amount) {
        if (amount >= 10000000) return '₹' + (amount / 10000000).toFixed(2) + ' Cr';
        if (amount >= 100000) return '₹' + (amount / 100000).toFixed(2) + ' Lac';
        return '₹' + Math.round(amount).toLocaleString('en-IN');
    }

    function estimateNewRegimeTax(grossAnnual) {
        const stdDed = 75000;
        const taxableIncome = Math.max(0, grossAnnual - stdDed);
        let tax = 0;
        if (taxableIncome <= 400000) tax = 0;
        else if (taxableIncome <= 800000) tax = (taxableIncome - 400000) * 0.05;
        else if (taxableIncome <= 1200000) tax = 20000 + (taxableIncome - 800000) * 0.10;
        else if (taxableIncome <= 1600000) tax = 60000 + (taxableIncome - 1200000) * 0.15;
        else if (taxableIncome <= 2000000) tax = 120000 + (taxableIncome - 1600000) * 0.20;
        else if (taxableIncome <= 2400000) tax = 200000 + (taxableIncome - 2000000) * 0.25;
        else tax = 300000 + (taxableIncome - 2400000) * 0.30;

        // Rebate u/s 87A with marginal relief (Finance Act 2025):
        // Up to ₹12L → full rebate. Just above ₹12L → tax cannot exceed excess over ₹12L.
        if (taxableIncome <= 1200000) {
            tax = Math.max(0, tax - 60000);
        } else {
            const excessOver12L = taxableIncome - 1200000;
            if (tax > excessOver12L) {
                tax = excessOver12L;
            }
        }
        // Cess
        tax = tax + tax * 0.04;
        return Math.round(tax);
    }

    function calculateSalary() {
        const annualCTC = parseINR(document.getElementById('annualCTC').value) || 0;
        const cityType = document.getElementById('cityType').value;
        const basicPercent = parseINR(document.getElementById('basicPercent').value) || 40;
        const monthlyBonus = parseINR(document.getElementById('monthlyBonus').value) || 0;
        const profTax = parseINR(document.getElementById('profTax').value) || 200;

        // Calculate components
        const annualBasic = annualCTC * (basicPercent / 100);
        const monthlyBasic = annualBasic / 12;

        const hraPercent = cityType === 'metro' ? 50 : 40;
        const monthlyHRA = monthlyBasic * (hraPercent / 100);

        const monthlyEmployerPF = monthlyBasic * 0.12;
        const monthlyEmployeePF = monthlyBasic * 0.12;
        const monthlyGratuity = monthlyBasic * 0.0481;

        // ESI only if gross <= 21000/month
        const grossBeforeESI = annualCTC / 12;
        const monthlyEmployerESI = grossBeforeESI <= 21000 ? grossBeforeESI * 0.0325 : 0;

        // Special Allowance = Monthly CTC - Basic - HRA - Employer PF - Gratuity - Employer ESI
        const monthlyCTC = annualCTC / 12;
        const monthlySpecialAllowance = Math.max(0, monthlyCTC - monthlyBasic - monthlyHRA - monthlyEmployerPF - monthlyGratuity - monthlyEmployerESI);

        // Gross Salary (what employee sees on payslip before deductions)
        const monthlyGross = monthlyBasic + monthlyHRA + monthlySpecialAllowance + monthlyBonus;

        // Estimate annual income tax (TDS)
        const annualGross = monthlyGross * 12;
        const annualTax = estimateNewRegimeTax(annualGross);
        const monthlyTDS = Math.round(annualTax / 12);

        // Total Deductions
        const totalMonthlyDeductions = monthlyEmployeePF + profTax + monthlyTDS;

        // In-Hand
        const monthlyInHand = monthlyGross - totalMonthlyDeductions;
        const annualInHand = monthlyInHand * 12;

        // GA4 Tracking
        trackCalculatorUsage('Salary Calculator', annualCTC);

        // Display Results
        document.getElementById('monthlyInHand').textContent = fmt(Math.round(monthlyInHand));
        document.getElementById('annualInHand').textContent = 'Annual In-Hand: ' + fmt(Math.round(annualInHand));

        // Earnings
        document.getElementById('resBasicPay').textContent = fmt(Math.round(monthlyBasic));
        document.getElementById('resHRA').textContent = fmt(Math.round(monthlyHRA));
        document.getElementById('resSpecialAllowance').textContent = fmt(Math.round(monthlySpecialAllowance));
        document.getElementById('resBonus').textContent = fmt(Math.round(monthlyBonus));
        document.getElementById('resGrossSalary').textContent = fmt(Math.round(monthlyGross));

        // Deductions
        document.getElementById('resEmployeePF').textContent = '- ' + fmt(Math.round(monthlyEmployeePF));
        document.getElementById('resProfTax').textContent = '- ' + fmt(Math.round(profTax));
        document.getElementById('resTDS').textContent = '- ' + fmt(Math.round(monthlyTDS));
        document.getElementById('resTotalDeductions').textContent = fmt(Math.round(totalMonthlyDeductions));

        // Employer Side
        document.getElementById('resEmployerPF').textContent = fmt(Math.round(monthlyEmployerPF));
        document.getElementById('resGratuity').textContent = fmt(Math.round(monthlyGratuity));
        document.getElementById('resEmployerESI').textContent = monthlyEmployerESI > 0 ? fmt(Math.round(monthlyEmployerESI)) : 'N/A';

        document.getElementById('results').classList.remove('hidden');
        document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
</script>
{% endblock %}
