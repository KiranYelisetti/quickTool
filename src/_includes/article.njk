---
layout: base.njk
---

<div class="container mx-auto px-4 py-8 md:py-12 max-w-4xl">
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-gray-500 dark:text-gray-400 mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a href="/" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
                    <i class="fas fa-home mr-2"></i>Home
                </a>
            </li>
            <li>
                <div class="flex items-center">
                    <i class="fas fa-chevron-right text-xs mx-2"></i>
                    <a href="/blog/" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Blog</a>
                </div>
            </li>
            <li aria-current="page">
                <div class="flex items-center">
                    <i class="fas fa-chevron-right text-xs mx-2"></i>
                    <span class="text-gray-700 dark:text-gray-200 truncate max-w-xs sm:max-w-none">{{ title }}</span>
                </div>
            </li>
        </ol>
    </nav>

    <!-- Article Header -->
    <header class="mb-10 text-center">
        {% if tags %}
        <div class="flex flex-wrap justify-center gap-2 mb-4">
            {% for tag in tags %}
                {% if tag != "post" %}
                <span class="bg-indigo-100 text-indigo-800 dark:bg-indigo-900 dark:text-indigo-300 text-xs font-semibold px-2.5 py-0.5 rounded uppercase">
                    {{ tag }}
                </span>
                {% endif %}
            {% endfor %}
        </div>
        {% endif %}
        
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">{{ title }}</h1>
        
        <div class="flex items-center justify-center text-sm text-gray-600 dark:text-gray-400 space-x-4">
            <div class="flex items-center">
                <i class="fas fa-user-circle mr-2 text-indigo-500"></i>
                <span>{{ author | default("QuickTools India Team") }}</span>
            </div>
            <span>&bull;</span>
            <div class="flex items-center">
                <i class="fas fa-calendar-alt mr-2 text-indigo-500"></i>
                <time datetime="{{ page.date }}">{{ page.date.toDateString() }}</time>
            </div>
            {% if readTime %}
            <span>&bull;</span>
            <div class="flex items-center">
                <i class="fas fa-clock mr-2 text-indigo-500"></i>
                <span>{{ readTime }} min read</span>
            </div>
            {% endif %}
        </div>
    </header>

    <!-- Main Content -->
    <article class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-6 md:p-10 lg:p-12 border-2 border-gray-100 dark:border-gray-700">
        <div class="prose prose-lg dark:prose-invert max-w-none prose-indigo prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white prose-a:text-indigo-600 dark:prose-a:text-indigo-400 hover:prose-a:text-indigo-800 transition-colors">
            {{ content | safe }}
        </div>
    </article>

    <!-- Author/Newsletter Section (Optional) -->
    <div class="mt-12 bg-gradient-to-br from-indigo-50 to-purple-50 dark:from-gray-800 dark:to-gray-700 rounded-2xl shadow-lg p-8 border-l-4 border-indigo-500">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Explore Our Free Tools</h3>
        <p class="text-gray-700 dark:text-gray-300 mb-4">
            Did you enjoy this article? We build completely free, privacy-friendly calculators for Indians. Check out our <a href="/home-loan-calculator/" class="text-indigo-600 dark:text-indigo-400 font-bold hover:underline">Home Loan Calculator</a>, <a href="/car-loan-calculator/" class="text-indigo-600 dark:text-indigo-400 font-bold hover:underline">Car Loan Calculator</a>, and <a href="/sip-calculator/" class="text-indigo-600 dark:text-indigo-400 font-bold hover:underline">SIP Calculator</a>.
        </p>
        <a href="/" class="inline-flex items-center bg-indigo-600 text-white font-semibold px-4 py-2 rounded-lg hover:bg-indigo-700 transition shadow-md">
            View All Tools <i class="fas fa-arrow-right ml-2"></i>
        </a>
    </div>
</div>
