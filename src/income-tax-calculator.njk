                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700"><td class="px-4 py-3 font-semibold dark:text-white">NSC</td><td class="px-4 py-3 text-center dark:text-gray-300">5 years</td><td class="px-4 py-3 text-center dark:text-gray-300">7.7%</td><td class="px-4 py-3 text-center dark:text-gray-300">Zero (Govt.)</td></tr>
                        </tbody>
