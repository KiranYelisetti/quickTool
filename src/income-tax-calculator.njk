                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700"><td class="px-4 py-3 font-semibold dark:text-white">ELSS Mutual Funds</td><td class="px-4 py-3 text-center dark:text-gray-300">3 years</td><td class="px-4 py-3 text-center text-green-600 font-bold">12-15%*</td><td class="px-4 py-3 text-center text-orange-600">Medium-High</td></tr>
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700"><td class="px-4 py-3 font-semibold dark:text-white">NPS (Tier-I)</td><td class="px-4 py-3 text-center dark:text-gray-300">Till 60</td><td class="px-4 py-3 text-center text-green-600 font-bold">9-12%*</td><td class="px-4 py-3 text-center text-orange-600">Medium</td></tr>
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700"><td class="px-4 py-3 font-semibold dark:text-white">LIC Premium</td><td class="px-4 py-3 text-center dark:text-gray-300">5-20 years</td><td class="px-4 py-3 text-center dark:text-gray-300">4-6%</td><td class="px-4 py-3 text-center dark:text-gray-300">Low</td></tr>
