            <!-- Section 80C Breakdown -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl border-2 border-gray-900 dark:border-gray-700 p-8">
                <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-6"><i class="fas fa-list-alt mr-2 text-emerald-600"></i>Section 80C Investment Options</h2>
                <div class="overflow-x-auto shadow-md rounded-lg">
