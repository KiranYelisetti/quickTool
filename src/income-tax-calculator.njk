</main>

{% block scripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        initAutoSave('income_tax_calc');
        calculateTax();
    });

    function fmt(amount) {
        if (amount >= 10000000) return '₹' + (amount / 10000000).toFixed(2) + ' Cr';
        if (amount >= 100000) return '₹' + (amount / 100000).toFixed(2) + ' Lac';
        return '₹' + Math.round(amount).toLocaleString('en-IN');
    }

    function calcOldRegimeTax(taxableIncome) {
        let tax = 0;
        if (taxableIncome <= 250000) {
            tax = 0;
        } else if (taxableIncome <= 500000) {
            tax = (taxableIncome - 250000) * 0.05;
        } else if (taxableIncome <= 1000000) {
            tax = 12500 + (taxableIncome - 500000) * 0.20;
        } else {
            tax = 12500 + 100000 + (taxableIncome - 1000000) * 0.30;
        }
        return tax;
    }

    function calcNewRegimeTax(taxableIncome) {
        let tax = 0;
        if (taxableIncome <= 400000) {
            tax = 0;
        } else if (taxableIncome <= 800000) {
            tax = (taxableIncome - 400000) * 0.05;
        } else if (taxableIncome <= 1200000) {
            tax = 20000 + (taxableIncome - 800000) * 0.10;
        } else if (taxableIncome <= 1600000) {
            tax = 60000 + (taxableIncome - 1200000) * 0.15;
        } else if (taxableIncome <= 2000000) {
            tax = 120000 + (taxableIncome - 1600000) * 0.20;
        } else if (taxableIncome <= 2400000) {
            tax = 200000 + (taxableIncome - 2000000) * 0.25;
        } else {
            tax = 300000 + (taxableIncome - 2400000) * 0.30;
        }
        return tax;
    }

    function calculateTax() {
        const grossSalary = parseFloat(document.getElementById('grossSalary').value) || 0;
        const otherIncome = parseFloat(document.getElementById('otherIncome').value) || 0;
        const d80C = Math.min(parseFloat(document.getElementById('deduction80C').value) || 0, 150000);
        const d80D = parseFloat(document.getElementById('deduction80D').value) || 0;
        const hra = parseFloat(document.getElementById('hraExemption').value) || 0;
        const homeLoan = Math.min(parseFloat(document.getElementById('homeLoanInterest').value) || 0, 200000);
        const nps = Math.min(parseFloat(document.getElementById('nps80CCD').value) || 0, 50000);
        const otherDed = parseFloat(document.getElementById('otherDeductions').value) || 0;

        const totalGross = grossSalary + otherIncome;

        // ---- OLD REGIME ----
        const oldStdDed = 50000;
        const totalOldDeductions = d80C + d80D + hra + homeLoan + nps + otherDed;
        const oldTaxableIncome = Math.max(0, totalGross - oldStdDed - totalOldDeductions);
        let oldTaxBeforeCess = calcOldRegimeTax(oldTaxableIncome);

        // Rebate u/s 87A (Old): up to ₹12,500 if taxable income ≤ ₹5L
        let oldRebate = 0;
        if (oldTaxableIncome <= 500000) {
            oldRebate = Math.min(oldTaxBeforeCess, 12500);
        }
        const oldTaxAfterRebate = Math.max(0, oldTaxBeforeCess - oldRebate);
        const oldCess = oldTaxAfterRebate * 0.04;
        const oldTotalTax = Math.round(oldTaxAfterRebate + oldCess);

        // ---- NEW REGIME ----
        const newStdDed = 75000;
        const newTaxableIncome = Math.max(0, totalGross - newStdDed);
        let newTaxBeforeCess = calcNewRegimeTax(newTaxableIncome);

        // Rebate u/s 87A (New): up to ₹60,000 if taxable income ≤ ₹12L
        let newRebate = 0;
        if (newTaxableIncome <= 1200000) {
            newRebate = Math.min(newTaxBeforeCess, 60000);
        }
        const newTaxAfterRebate = Math.max(0, newTaxBeforeCess - newRebate);
        const newCess = newTaxAfterRebate * 0.04;
        const newTotalTax = Math.round(newTaxAfterRebate + newCess);

        // GA4 Tracking
        trackCalculatorUsage('Income Tax Calculator', grossSalary);

        // ---- Display Old Regime ----
        document.getElementById('oldGrossIncome').textContent = fmt(totalGross);
        document.getElementById('oldStdDeduction').textContent = '- ' + fmt(oldStdDed);
        document.getElementById('oldChapterDeductions').textContent = '- ' + fmt(totalOldDeductions);
        document.getElementById('oldTaxableIncome').textContent = fmt(oldTaxableIncome);
        document.getElementById('oldTaxBeforeCess').textContent = fmt(Math.round(oldTaxBeforeCess));
        document.getElementById('oldRebate').textContent = oldRebate > 0 ? '- ' + fmt(oldRebate) : '₹0';
        document.getElementById('oldCess').textContent = fmt(Math.round(oldCess));
        document.getElementById('oldTotalTax').textContent = fmt(oldTotalTax);
        document.getElementById('oldEffectiveRate').textContent = totalGross > 0 ? ((oldTotalTax / totalGross) * 100).toFixed(1) + '%' : '0%';
        document.getElementById('oldMonthlyTax').textContent = fmt(Math.round(oldTotalTax / 12));

        // ---- Display New Regime ----
        document.getElementById('newGrossIncome').textContent = fmt(totalGross);
        document.getElementById('newStdDeduction').textContent = '- ' + fmt(newStdDed);
        document.getElementById('newTaxableIncome').textContent = fmt(newTaxableIncome);
        document.getElementById('newTaxBeforeCess').textContent = fmt(Math.round(newTaxBeforeCess));
        document.getElementById('newRebate').textContent = newRebate > 0 ? '- ' + fmt(newRebate) : '₹0';
        document.getElementById('newCess').textContent = fmt(Math.round(newCess));
        document.getElementById('newTotalTax').textContent = fmt(newTotalTax);
        document.getElementById('newEffectiveRate').textContent = totalGross > 0 ? ((newTotalTax / totalGross) * 100).toFixed(1) + '%' : '0%';
        document.getElementById('newMonthlyTax').textContent = fmt(Math.round(newTotalTax / 12));

        // ---- Verdict ----
        const diff = Math.abs(oldTotalTax - newTotalTax);
        if (newTotalTax < oldTotalTax) {
            document.getElementById('verdictText').textContent = '✅ New Regime saves you ' + fmt(diff) + '/year!';
            document.getElementById('verdictText').className = 'text-xl font-bold text-emerald-600 mb-2';
        } else if (oldTotalTax < newTotalTax) {
            document.getElementById('verdictText').textContent = '✅ Old Regime saves you ' + fmt(diff) + '/year!';
            document.getElementById('verdictText').className = 'text-xl font-bold text-orange-600 mb-2';
        } else {
            document.getElementById('verdictText').textContent = '⚖️ Both regimes result in the same tax!';
            document.getElementById('verdictText').className = 'text-xl font-bold text-blue-600 mb-2';
        }
        document.getElementById('verdictSavings').textContent = 'Old Regime: ' + fmt(oldTotalTax) + '/year (' + fmt(Math.round(oldTotalTax/12)) + '/month) | New Regime: ' + fmt(newTotalTax) + '/year (' + fmt(Math.round(newTotalTax/12)) + '/month)';

        document.getElementById('results').classList.remove('hidden');
        document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
</script>
{% endblock %}
