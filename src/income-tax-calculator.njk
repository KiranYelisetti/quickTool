    <!-- Financial Disclaimer -->
    <div class="mt-12 bg-yellow-50 dark:bg-yellow-900 dark:bg-opacity-20 border-l-4 border-yellow-500 p-6 max-w-5xl mx-auto mb-8 rounded-r-lg">
