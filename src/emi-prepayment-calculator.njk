{% block scripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        initAutoSave('prepay_calc');
        calculatePrepayment();
    });

    function fmt(amount) {
        if (amount >= 10000000) return '₹' + (amount / 10000000).toFixed(2) + ' Cr';
        if (amount >= 100000) return '₹' + (amount / 100000).toFixed(2) + ' Lac';
        return '₹' + Math.round(amount).toLocaleString('en-IN');
    }

    function calculatePrepayment() {
        const P = parseINR(document.getElementById('loanAmount').value) || 0;
        const annualRate = parseINR(document.getElementById('interestRate').value) || 0;
        const tenureYears = parseINR(document.getElementById('loanTenure').value) || 0;
        const monthlyExtra = parseINR(document.getElementById('monthlyExtra').value) || 0;
        const lumpSum = parseINR(document.getElementById('lumpSum').value) || 0;

        const r = annualRate / 12 / 100;
        const n = tenureYears * 12;

        if (P <= 0 || r <= 0 || n <= 0) return;

        // Original EMI
        const emi = (P * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
        const origTotalPaid = emi * n;
        const origTotalInterest = origTotalPaid - P;

        // Simulate with prepayment
        let balance = P - lumpSum; // Apply lump sum immediately
        if (balance < 0) balance = 0;
        let totalPaidWithPrepay = lumpSum;
        let totalInterestWithPrepay = 0;
        let month = 0;

        while (balance > 0 && month < n * 2) { // Safety limit
            month++;
            const interestThisMonth = balance * r;
            let principalThisMonth = emi - interestThisMonth + monthlyExtra;

            if (principalThisMonth > balance) {
                // Last month — pay only what's needed
                totalPaidWithPrepay += balance + interestThisMonth;
                totalInterestWithPrepay += interestThisMonth;
                balance = 0;
            } else {
                balance -= principalThisMonth;
                totalPaidWithPrepay += emi + monthlyExtra;
                totalInterestWithPrepay += interestThisMonth;
            }
        }

        const monthsSaved = n - month;
        const interestSaved = origTotalInterest - totalInterestWithPrepay;

        // Calculate new end date
        const today = new Date();
        const origEnd = new Date(today);
        origEnd.setMonth(origEnd.getMonth() + n);
        const newEnd = new Date(today);
        newEnd.setMonth(newEnd.getMonth() + month);

        // GA4 Tracking
        trackCalculatorUsage('EMI Prepayment Calculator', P);

        // Display
        document.getElementById('interestSaved').textContent = fmt(Math.round(interestSaved));
        const yearsSaved = Math.floor(monthsSaved / 12);
        const remainingMonths = monthsSaved % 12;
        let timeSavedText = '';
        if (yearsSaved > 0) timeSavedText += yearsSaved + ' year' + (yearsSaved > 1 ? 's' : '');
        if (remainingMonths > 0) timeSavedText += (timeSavedText ? ' ' : '') + remainingMonths + ' month' + (remainingMonths > 1 ? 's' : '');
        if (!timeSavedText) timeSavedText = '0 months';
        document.getElementById('timeSaved').textContent = timeSavedText;
        document.getElementById('newEndDate').textContent = newEnd.toLocaleDateString('en-IN', { year: 'numeric', month: 'short' });

        // Comparison Table
        document.getElementById('origEMI').textContent = fmt(Math.round(emi));
        document.getElementById('newEMI').textContent = fmt(Math.round(emi)) + ' + ' + fmt(monthlyExtra);
        document.getElementById('origTenure').textContent = tenureYears + ' years (' + n + ' months)';
        document.getElementById('newTenure').textContent = Math.floor(month / 12) + ' yrs ' + (month % 12) + ' months';
        document.getElementById('tenureSaved').textContent = timeSavedText + ' saved!';
        document.getElementById('origInterest').textContent = fmt(Math.round(origTotalInterest));
        document.getElementById('newInterest').textContent = fmt(Math.round(totalInterestWithPrepay));
        document.getElementById('interestSavedTable').textContent = fmt(Math.round(interestSaved)) + ' saved!';
        document.getElementById('origTotal').textContent = fmt(Math.round(origTotalPaid));
        document.getElementById('newTotal').textContent = fmt(Math.round(totalPaidWithPrepay));
        document.getElementById('totalSaved').textContent = fmt(Math.round(origTotalPaid - totalPaidWithPrepay)) + ' saved!';

        document.getElementById('results').classList.remove('hidden');
        document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
</script>
{% endblock %}
